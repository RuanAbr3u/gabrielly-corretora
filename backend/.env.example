# ===========================================
# VARIÁVEIS DE AMBIENTE - SEGURANÇA AUDITADA
# ===========================================
# 🔒 NUNCA commit .env real - use este arquivo como template
# 1. Copie este arquivo para .env
# 2. Preencha os valores reais
# 3. Adicione .env ao .gitignore

# ===== AMBIENTE =====
NODE_ENV=production
# Em desenvolvimento: NODE_ENV=development
PORT=3000
HOST=localhost

# ===== BANCO DE DADOS (PostgreSQL) =====
# Configurações de conexão segura
DB_HOST=seu-servidor-postgres.com
DB_PORT=5432
DB_NAME=gabrielly_corretora
DB_USER=seu_usuario_postgres
DB_PASSWORD=sua_senha_muito_forte_aqui_123!@#

# ===== JWT TOKENS - CRÍTICO DE SEGURANÇA =====
# 🔴 IMPORTANTE: Gere uma chave segura de 32+ caracteres
# Comando: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=gere_uma_chave_aleatoria_de_32_caracteres_ou_mais_aqui
JWT_EXPIRES_IN=7d
# Em produção, considere reduzir para 1d e implementar refresh tokens

# ===== CORS - FRONTENT URLs =====
# ✅ PRODUÇÃO: Use domínio específico
FRONTEND_URL=https://seu-dominio.com
# ❌ NUNCA use: FRONTEND_URL=*

# ===== HTTPS/SEGURANÇA =====
# Force HTTPS em produção
FORCE_HTTPS=true
# Necessário para que cookies sejam enviados com flag 'secure'

# ===== SUPABASE (Opcional) =====
# Usar apenas chave ANON (é seguro expor)
SUPABASE_URL=https://seu-project.supabase.co
SUPABASE_KEY=sua_chave_anon_aqui
SUPABASE_SERVICE_KEY=sua_chave_service_role_aqui
# ⚠️ NUNCA exponha SERVICE_ROLE_KEY no frontend
# A SERVICE_KEY é usada apenas no backend para operações administrativas

# ===== EMAIL (Gmail/SMTP) =====
# Configuração para envio de emails de contato
# 🔴 IMPORTANTE: Use "App Password" do Gmail, NÃO sua senha normal
# Tutorial: https://support.google.com/mail/answer/185833
EMAIL_USER=Gabriellycorretora1@gmail.com
EMAIL_PASSWORD=sua_senha_de_app_do_gmail_aqui
# EMAIL_DESTINO=Gabriellycorretora1@gmail.com (opcional, já definido no código)

# ===== UPLOAD & STORAGE =====
MAX_FILE_SIZE=5242880
# 5MB em bytes (5 * 1024 * 1024)
UPLOAD_DIR=./uploads

# ===== LOGS =====
LOG_LEVEL=error
# Em desenvolvimento: LOG_LEVEL=debug
# Em produção: LOG_LEVEL=error

# ===== MONITORAMENTO (OPCIONAL) =====
# Sentry, DataDog, etc.
# SENTRY_DSN=seu_sentry_dsn_aqui

# ===== SEGURANÇA ADICIONAL =====
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50

# Tempo de expiração de sessão (7 dias)
SESSION_EXPIRY_DAYS=7

